{
  "name": "joke-generator-api",
  "version": "1.0.0",
  "description": "A production-quality Joke Generator REST API built with Express",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "test": "jest --forceExit",
    "test:ci": "jest --ci --reporters=default --reporters=jest-junit --coverage --coverageReporters=lcov --forceExit",
    "lint": "eslint .",
    "smoke": "node smoke.js"
  },
  "keywords": [
    "joke",
    "api",
    "express",
    "nodejs"
  ],
  "author": "",
