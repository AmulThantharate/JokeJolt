# JokeJolt Production Terraform Configuration
# Copy this file to terraform.tfvars and update with your values

# ─── General Configuration ───────────────────────────────────────────────────
region      = "us-east-1"
environment = "production"
project_name = "jokejolt"

# ─── EKS Configuration ───────────────────────────────────────────────────────
cluster_version              = "1.28"
cluster_endpoint_public_access  = true
cluster_endpoint_private_access = true

# ─── Node Group Configuration ───────────────────────────────────────────────
node_group_instance_types = ["t3.medium"]
node_group_desired_size   = 3
node_group_min_size       = 2
node_group_max_size       = 10
node_disk_size            = 50

# ─── Kubernetes Deployment ───────────────────────────────────────────────────
k8s_namespace    = "jokejolt-production"
k8s_replicas     = 3
k8s_image_tag    = "main-latest"

# ─── Auto-scaling Configuration ──────────────────────────────────────────────
hpa_min_replicas                = 3
hpa_max_replicas                = 20
hpa_cpu_target_utilization      = 60
hpa_memory_target_utilization   = 75

# ─── SSL/TLS Configuration ───────────────────────────────────────────────────
# Get this from AWS Certificate Manager
ssl_certificate_arn = "arn:aws:acm:us-east-1:123456789012:certificate/your-cert-id"

# ─── Domain Configuration ────────────────────────────────────────────────────
domain_names = ["jokejolt.example.com", "api.jokejolt.example.com"]

# ─── Security ─────────────────────────────────────────────────────────────────
# Restrict access to your IP range in production
allowed_cidr_blocks = ["0.0.0.0/0"]  # Change to your IP range for production

# ─── Monitoring ───────────────────────────────────────────────────────────────
enable_cloudwatch_logs    = true
cloudwatch_log_retention  = 30
enable_container_insights = true

# ─── Additional Tags ─────────────────────────────────────────────────────────
additional_tags = {
  Team        = "platform"
  CostCenter  = "jokejolt"
  ManagedBy   = "terraform"
}
